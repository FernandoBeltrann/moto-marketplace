NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=MotoClick.mx
NEXT_PUBLIC_LOGO_TEXT=motoclick.mx
NEXT_PUBLIC_FINVA_WHATSAPP=5215610420474
# Si una moto no tiene `purchase_url` en Supabase, los CTAs del calculador usan esta URL (portal Finva, etc.).
# NEXT_PUBLIC_DEFAULT_PURCHASE_URL=https://ejemplo.com/iniciar-compra
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel — ID numérico del administrador de eventos
# NEXT_PUBLIC_META_PIXEL_ID=2173133536821881
NEXT_PUBLIC_META_PIXEL_ID=

# Optional Supabase lead storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=marketplace_leads
SUPABASE_MOTORCYCLES_TABLE=motorcycles
# Tabla de reseñas por moto (ver sql/motorcycle_reviews.sql). Por defecto: motorcycle_reviews
# SUPABASE_MOTORCYCLE_REVIEWS_TABLE=motorcycle_reviews
# Si las fotos están en otro dominio (CDN), lista hostnames separados por coma:
# NEXT_PUBLIC_CATALOG_IMAGE_HOSTS=images.micdn.com
# Solo para builds/CI sin Supabase (usa data/motorcycle-seed.ts). No uses en producción.
# SKIP_DB_CATALOG=1

# PostHog (opcional). Sin token no se inicializa el SDK (evita "Failed to fetch" en consola).
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Ingestión directa EU: NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Reverse proxy gestionado (ej. t.tudominio.com en PostHog → CNAME): NEXT_PUBLIC_POSTHOG_HOST=https://t.tudominio.com
# Desactivar por completo: NEXT_PUBLIC_POSTHOG_DISABLE=1
# En dev forzar comportamiento prod (proxy Next /ingest): NEXT_PUBLIC_POSTHOG_USE_PROXY=1

# Optional Finva CRM webhook. If present, every lead is posted here first.
FINVA_CRM_WEBHOOK_URL=

# ─── Mercado Pago Checkout Bricks (Payment Brick) ────────────────────────────
# Credenciales: https://www.mercadopago.com.mx/developers/panel/app
#
# Local / Desarrollo  → usa credenciales de PRUEBA (prefijo TEST-)
#   NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   MERCADOPAGO_ACCESS_TOKEN=TEST-1234567890123456-070801-abcdef...-1234567890
#
# Producción         → usa credenciales productivas (prefijo APP_USR-)
#   NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   MERCADOPAGO_ACCESS_TOKEN=APP_USR-1234567890123456-070801-abcdef...-1234567890
#
# Public key: se expone al cliente y es la que carga el SDK de Bricks.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-5e5640b5-c953-44ac-bb5a-456366c3c359
# Access token: solo en el servidor (procesa pagos vía Payments API). NUNCA NEXT_PUBLIC_.
MERCADOPAGO_ACCESS_TOKEN=TEST-6805025445600636-040914-d9b411ccc103012a8f30ca01143f7648-2620561523
# Máximo de mensualidades en tarjeta de crédito (débito siempre = 1). Default: 24.
NEXT_PUBLIC_MERCADOPAGO_MAX_INSTALLMENTS=24
# URL pública del webhook de pagos. Debe terminar en /api/payments/webhook.
# Se envía como `notification_url` en cada pago y/o se configura en
# https://www.mercadopago.com.mx/developers/panel/app → Webhooks → Tópico "Payments".
MERCADOPAGO_WEBHOOK_URL=https://tudominio.com/api/payments/webhook
# Clave secreta para validar la firma `x-signature` de cada notificación.
# Se obtiene en el panel: Webhooks → Configurar notificaciones → "Clave secreta".
# CRÍTICO: sin esta variable la API rechaza notificaciones en producción.
MERCADOPAGO_WEBHOOK_SECRET=
# (Opcional) Tabla Supabase donde se persiste el último estado de cada pago.
# Crea la tabla con `sql/motoclick_payments.sql`. Default: motoclick_payments
SUPABASE_PAYMENTS_TABLE=motoclick_payments
# (Opcional) Statement descriptor que aparece en el estado de cuenta del comprador (≤22 chars).
MERCADOPAGO_STATEMENT_DESCRIPTOR=MotoClick

# ─── Resend (correos transaccionales) ────────────────────────────────────────
# Crea la API key en https://resend.com/api-keys y verifica el dominio en
# https://resend.com/domains. Sin estas variables NO se envían correos.
RESEND_API_KEY=
# Remitente (debe estar en un dominio verificado en Resend). Ej.:
#   RESEND_FROM_EMAIL="MotoClick <noreply@motoclick.mx>"
RESEND_FROM_EMAIL=MotoClick <noreply@motoclick.mx>
# Correo interno que recibe la notificación de cada compra aprobada.
RESEND_NOTIFY_EMAIL=notificaciones@finva-app.com
# (Opcional) Bcc opcional para auditoría interna.
# RESEND_BCC_EMAIL=ops@finva-app.com
