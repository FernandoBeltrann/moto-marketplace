NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=MotoClick
NEXT_PUBLIC_LOGO_TEXT=motoclick.mx
NEXT_PUBLIC_FINVA_WHATSAPP=5215610420474
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Optional Supabase lead storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=marketplace_leads
SUPABASE_MOTORCYCLES_TABLE=motorcycles
# Si las fotos están en otro dominio (CDN), lista hostnames separados por coma:
# NEXT_PUBLIC_CATALOG_IMAGE_HOSTS=images.micdn.com
# Solo para builds/CI sin Supabase (usa data/motorcycle-seed.ts). No uses en producción.
# SKIP_DB_CATALOG=1

# PostHog (opcional). Sin token no se inicializa el SDK (evita "Failed to fetch" en consola).
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Ingestión directa EU: NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Reverse proxy gestionado (ej. t.tudominio.com en PostHog → CNAME): NEXT_PUBLIC_POSTHOG_HOST=https://t.tudominio.com
# Desactivar por completo: NEXT_PUBLIC_POSTHOG_DISABLE=1
# En dev forzar comportamiento prod (proxy Next /ingest): NEXT_PUBLIC_POSTHOG_USE_PROXY=1

# Optional Finva CRM webhook. If present, every lead is posted here first.
FINVA_CRM_WEBHOOK_URL=
